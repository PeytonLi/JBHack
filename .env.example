# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# Sentry (for target service)
SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_WEBHOOK_SECRET=your-sentry-webhook-client-secret

# GitHub (for PR creation)
GITHUB_TOKEN=your-github-token
# Required for autopilot. Use 'owner/repo'. Full https/ssh URLs and a trailing
# '.git' are accepted and normalized automatically at startup.
GITHUB_REPO=your-github-username/autoscribe-throwaway

# App ports (defaults, override if needed)
AGENT_PORT=8001
TARGET_PORT=8000

# Local SecureLoop runtime
SECURE_LOOP_HOME=
SECURE_LOOP_AGENT_URL=http://127.0.0.1:8001
SECURE_LOOP_ALLOW_DEBUG_ENDPOINTS=0
SECURE_LOOP_USE_FAKE_CODEX=0
